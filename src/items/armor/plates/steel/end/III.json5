            thickness: 1.016,
          },
        ],

        encumbrance: 4,

        coverage: 34,
        covers: ["torso"],
        specifically_covers: ["torso_upper"],
      },

      {
        material: [
          { type: "mc_steel", covered_by_mat: 100, thickness: 7.616 },
          {
