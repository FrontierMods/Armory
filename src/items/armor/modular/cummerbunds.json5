[
  {
    id: "cummerbund/perroz",
    type: "ITEM",
    subtypes: ["ARMOR"],

    /* 
      SOURCES
        https://perrozdesigns.com/products/laser-cut-cummerbunds

        https://eu.directactiongear.com/en/skeletonized-cummerbund-slim.html
        - weight reference
    */

    name: {
      str: "laser-cut MOLLE cummerbunds",
      str_pl: "pairs of laser-cut MOLLE cummerbunds",
    },
    description: "A pair of lightweight cummerbunds, which wrap around the stomach end of a plate carrier in order to keep the carrier firmly against the body.  This model features a sheer PALS grid, with large sections of the grid cut out in order to reduce weight, without having any negative effect on the MOLLE mounting capability.  Without a pair of cummerbunds, wearing any plate carrier will be uncomfortable.  Attach these to reduce baseline plate carrier encumbrance.",

    variant_type: "gun",
    variants: [
      {
        from: [
          ["multicam", 2],
          "multicam_black",
          "black",
          "coyote",
          "woodland",
        ],
        plural: true,

        name: {
          str: "Perroz Designs laser-cut MOLLE cummerbunds",
          str_pl: "pairs of Perroz Designs laser-cut MOLLE cummerbunds",
        },
        description: "A pair of lightweight hook-and-loop cummerbunds with a sheer laser-cut PALS grid.  You should attach these to a plate carrier in order to reduce its baseline encumbrance.",
      },
    ],

    // we presume that, for the reference model listing, the weight in grams is more accurate, because it's sold on the European market and is manufactured in Poland
    weight: "210 g",
    dimensions: {
      type: "rectangle",
      // * doubled because the item is modelled as a pair
      count: 2,

      length: "21.5 in",
      width: "4 in",
      // * thickness
      // * presumed
      height: "0.75 mm",

      trim: 0.025,
      soft: true,
    },

    symbol: "[",
    color: "dark_gray",

    material: ["nylon"],
    looks_like: "single_sling",
    repairs_like: "single_sling",

    armor: [
      {
        material: [
          {
            type: "nylon",
            covered_by_mat: 100,
            thickness: 0.75,
          },
        ],

        encumbrance: -12,

        coverage: 8,
        cover_melee: 4,
        cover_ranged: 8,

        covers: ["torso"],
        specifically_covers: ["torso_lower"],

        // volume_encumber_modifier: 0.3,
      },
    ],

    use_action: [
      {
        type: "attach_molle",
        // * 4.5 slots × 2
        // * we subtract 1 to prevent mounting three large MOLLE pouches where they couldn't fit
        size: 8,
      },
      {
        type: "detach_molle",
      },
    ],

    flags: ["WATER_FRIENDLY", "CANT_WEAR", "CUMMERBUND", "CUMMERBUND_VELCRO"],

    // 80 CAD
    // sold as a set
    price: "58 USD 40 cents",
    price_postapoc: "2 USD",
  },
  {
