  {
    id: "pouch/handcuffs/511",
    inherit: ["@pouch/small", "@holster"],
    type: "ITEM",

    /*
      SOURCES
        https://www.511tactical.com/flex-cuff-pouch.html

        https://www.kantas.com.tw/product/nij-approved-handcuffs-9-45-oz-chain-standard-size/
        - dimensions of a pair of handcuffs
    */

    name: {
      str: "handcuff pouch",
      str_pl: "handcuff pouches",
    },
    description: "A nylon pouch for storing handcuffs.  Can also store a bit of cordage.",

    variant_type: "gun",
    variants: [
      {
        from: [["black", 2], ["coyote", 2], "ranger"],

        name: {
          str: "5.11 Tactical Flex handcuffs pouch",
          str_pl: "5.11 Tactical Flex handcuffs pouches",
        },
        description: "A square nylon pouch with a flap.  Intended for holding chain handcuffs, to be worn by a sworn officer of the law.  Should also be able to store a bit of cordage.",
      },
    ],

    weight: "90 g",
    dimensions: {
      type: "rectangle",

      length: "4 mm",
      width: "3.5 in",
      height: "4 in",

      trim: 0.075,
      soft: true,
    },

    material: ["nylon"],

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Handcuff pouch",

        max_contains_weight: {
          math: ["9.45 oz" /* weight of the 'cuffs */, { op: "multiply", value: 2 }],
        },
        max_contains_volume: {
          math: [
            "6 mm" /* overall thickness  */,
            {
              op: "multiply",
              value: { ref: "@constants", key: "pi" },
            },
            {
              op: "multiply",
              value: {
                math: ["9 in", { op: "divide", value: 2 }, { op: "pow", value: 2 }],
              },
            },
            // * double for a _pair_ of handcuffs tied by a chain
            { op: "multiply", value: 2 },
          ],
        },
        max_item_length: "9 in",
      },
    ],

    price: "26 USD",
  },
