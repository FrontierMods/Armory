  {
    id: "pouch/deployment/condor",
    inherit: ["@pouch/large", "@pouch/leg"],
    type: "ITEM",
    subtypes: ["ARMOR"],

    /*
      SOURCES
        https://condoroutdoor.com/products/condor-deployment-bag

        https://www.military1st.com/127-001-condor-modular-style-deployment-bag-olive-drab.html
        - weight
    */

    /*
      NOTES
        - small straps on the side of pouches are not currently modelled
        - has an interior separator inside the main pocket, which it didn't seem wise to model, since there's no way to separate volume of main pocket from volume of separator 'pocket' without breaking something about pocket management for the player
        - unlike many other pouches, this one can be worn directly over the shoulder
    */

    name: {
      str: "deployment bag",
    },
    description: "A small nylon bag.  Can be worn over the shoulder or strapped to webbing.  Has plenty of pockets.",

    variant_type: "gun",
    variants: [
      {
        from: [["multicam", 2], ["black", 2], ["coyote", 2], "red"],

        name: {
          str: "Condor deployment bag",
        },
        description: "A small nylon bag that has both MOLLE straps and a shoulder strap.  It can be worn over the shoulder or attached to a PALS webbing.  Best used on an expedition where you may not need a lot of ammo, but would require food, drink, medication, or other short-term supplies.",
      },
    ],

    weight: "550 g",
    dimensions: {
      type: "rectangle",

      length: "5.5 in",
      width: "12 in",
      height: "6 in",
      trim: [0.1 /* bounding box reduction */, 0.8 /* from bounding box to compressed volume */],
      soft: true,
    },

    material: ["nylon", "plastic"],
    looks_like: "fanny",
    repairs_like: "backpack",

    armor: [
      {
        encumbrance: [1, 4],

        volume_encumber_modifier: 0.3,

        coverage: 38,
        covers: ["torso"],
        specifically_covers: ["torso_lower"],
      },
    ],

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Deployment bag front pocket",

        max_contains_weight: "1 kg 500 g",
        // * from eyeballed dimensions
        max_contains_volume: {
          math: [
            "1 in",
            { op: "multiply", value: "9 in" },
            { op: "multiply", value: "5 in" },
            { op: "trim", value: 0.05 },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "width"], raw: true },
            { op: "trim", value: 0.05 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 110,
      },
      {
        pocket_type: "CONTAINER",

        description: "Deployment bag front pocket thin pouch",

        max_contains_weight: "100 g",
        // * from assumed dimensions
        max_contains_volume: {
          math: [
            "0.125 in",
            { op: "multiply", value: "4.5 in" },
            { op: "multiply", value: "3.75 in" },
          ],
        },
        max_item_length: { math: ["4.5 in", { op: "trim", value: 0.05 }] },

        moves: 160,
      },
      {
        pocket_type: "CONTAINER",

        description: "Deployment bag front pocket thin pouch",

        max_contains_weight: "100 g",
        // * from assumed dimensions
        max_contains_volume: {
          math: [
            "0.125 in",
            { op: "multiply", value: "4.5 in" },
            { op: "multiply", value: "3.75 in" },
          ],
        },
        max_item_length: { math: ["4.5 in", { op: "trim", value: 0.05 }] },

        moves: 160,
