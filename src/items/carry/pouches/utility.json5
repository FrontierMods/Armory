[
  {
    id: "pouch/canteen/tt/1qt",
    inherit: ["@pouch/medium"],
    type: "ITEM",

    /*
      SOURCES
        https://tacticaltailor.com/canteen-utility-pouch/

        https://www.entrygear.com/product.asp?id=TT-10049
        - weight
    */

    name: {
      str: "one-quart canteen pouch",
    },
    description: "A large nylon pouch that can hold a 1-quart canteen, like those issued to the U.S. soldiers.  Can serve as an impromptu dump pouch.",

    variant_type: "gun",
    variants: [
      {
        from: ["multicam", "coyote", "ranger"],

        name: {
          str: "Tactical Tailor canteen pouch",
          str_pl: "Tactical Tailor canteen pouches",
        },
        description: "A large nylon pouch, intended to hold a single 1-quart canteen, like those issued to the U.S. G.I.'s.  Can serve as an impromptu dump pouch.",
      },
    ],

    weight: "133 g",
    dimensions: {
      type: "rectangle",

      length: "5 in",
      width: "3 mm",
      height: "8.5 in",
      trim: 0.05,
      soft: true,
    },

    material: ["nylon", "plastic"],
    repairs_like: "legrig",
    looks_like: "holster",

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Canteen pouch",

        max_contains_weight: "3 kg",
        max_contains_volume: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            {
              op: "multiply",
              value: { ref: "$", path: ["dimensions", "length"], raw: true },
            },
            { op: "multiply", value: "3 in" },
            { op: "trim", value: 0.05 },
          ],
        },
        // * no minimum length because without the canteen, this is a dump pouch
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "trim", value: 0.05 },
            { op: "convert", value: "mm" },
          ],
        },

        volume_encumber_modifier: 0.5,
      },
    ],

    price: "35 USD",
  },
  {
    id: "pouch/dump/bfg",
    inherit: ["@pouch/medium"],
    type: "ITEM",

    /*
      SOURCES
        https://www.blueforcegear.com/ten-speed-ultralight-dump-pouch.html
    */

    // * unfolded

    name: {
      str: "compact dump pouch",
      str_pl: "compact dump pouches",
    },
    description: "A nylon pouch for collecting items, primarily empty magazines, for sorting later.  It is currently unfolded and is ready to collect, taking up a fair bit of space when full.  Activate to fold back.",

    variant_type: "gun",
    variants: [
      {
        from: [["multicam", 4], ["ranger", 2], ["coyote", 2], "multicam_black", "black"],

        name: {
          str: "Blue Force Gear dump pouch",
          str_pl: "Blue Force Gear dump pouches",
        },
        description: "A nylon pouch for collecting items, primarily empty magazines, for sorting later.  It is currently unfolded and is ready to collect, taking up a fair bit of space when full.  Activate to fold back.",
      },
    ],

    weight: "61 g",
    // * the resulting volume of the pouch will be the same in both folded and unfolded states
    dimensions: {
      type: "rectangle",

      length: "3 in",
      width: "3.5 in",
      height: "1 in",
      trim: 0.25,
      soft: true,
    },

    material: ["nylon", "plastic"],
    repairs_like: "legrig",
    looks_like: "holster",

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Dump pouch",

        max_contains_weight: "5 kg",
        max_contains_volume: "3.5 L",
        max_item_length: "250 mm",

        volume_encumber_modifier: 2.5,
      },
    ],

    use_action: {
      type: "transform",
      target: "pouch/dump/bfg:folded",

      menu_text: "Fold",
      msg: "You fold the dump pouch.",
    },

    price: "59 USD 95 cents",
  },
  {
    id: "pouch/dump/bfg:folded",
    inherit: ["pouch/dump/bfg"],
    type: "ITEM",

    name: {
      str: "compact dump pouch (folded)",
      str_pl: "compact dump pouches (folded)",
    },
    description: "A nylon pouch for collecting items, primarily empty magazines, for sorting later.  It is currently folded for storing and provides no container capacity, and must be unfolded to be useful.  Activate to unfold.",

    variant_type: "gun",
    variants: [
      {
        from: [["multicam", 4], ["ranger", 2], ["coyote", 2], "multicam_black", "black"],

        name: {
          str: "FROG.PRO dump pouch (folded)",
          str_pl: "FROG.PRO dump pouches (folded)",
        },
        description: "A nylon pouch for collecting items, primarily empty magazines, for sorting later.  It is currently folded for storing and provides no container capacity, and must be unfolded to be useful.  Activate to unfold.",
      },
    ],

    use_action: {
      type: "transform",
      target: "pouch/dump/bfg",

      menu_text: "Unfold",
      msg: "You unfold the dump pouch.",
    },
  },
  {
    id: "pouch/ammo/condor",
    inherit: ["@pouch/medium", "@collapse_contents"],
    type: "ITEM",

    /*
      SOURCES
        https://condoroutdoor.com/products/condor-ammo-pouch

        https://www.smithandedwards.com/products/condor-ammo-pouch-20297.html
        - weight

        https://www.gearzonetactical.com/Condor-Ammo-Pouch--Multicam_p_3542.html
        - variants
    */

    name: {
      str: "loose ammo pouch",
      str_pl: "loose ammo pouches",
    },
    description: "A nylon box pouch with a flap.  While intended to carry loose ammunition, it can be used as an impromptu dump pouch of a more general variety.",

    variant_type: "gun",
    variants: [
      {
        from: [["multicam", 2], ["black", 2], ["coyote", 2], "ranger"],

        name: {
          str: "Condor loose ammo pouch",
          str_pl: "Condor loose ammo pouches",
        },
        description: "A nylon box pouch with a flap.  While intended to carry loose ammunition, it can be used as an impromptu dump pouch of a more general variety.",
      },
    ],

    weight: "0.31 lbs",
    dimensions: {
      type: "rectangle",

      length: "4 mm",
      width: "6.5 in",
      height: "7 in",
      soft: true,
    },

    material: ["nylon", "plastic"],

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Loose ammo pouch",

        max_contains_weight: "4 kg",
        max_contains_volume: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            {
              op: "multiply",
              value: { ref: "$", path: ["dimensions", "width"], raw: true },
            },
            // * 3 in. is the stated depth of the pouch
            { op: "multiply", value: "3 in" },
            { op: "trim", value: 0.05 },
          ],
        },
      },
    ],

    price: "28 USD 95 cents",
  },
  {
    id: "pouch/water_bottle/ft",
    inherit: ["@pouch/small"],
    type: "ITEM",

    /*
      SOURCES
        https://www.firsttactical.com/products/tactix-series-bottle-pouch-1-0-liter
    */

    name: {
      str: "water bottle pouch",
      str_pl: "water bottle pouches",
    },
    description: "A tall nylon pouch for storing water bottles.  Takes in tall bottles up to 1.5L in capacity.",

    variant_type: "gun",
    variants: [
      {
        from: ["black", "coyote", "olive"],

        name: {
          str: "First Tactical water bottle pouch",
          str_pl: "First Tactical water bottle pouches",
        },
        description: "A tall nylon pouch for storing water bottles.  The flap can be securely held closed by a robust plastic buckle.  Takes in tall bottles up to 1.5L in capacity.",
      },
    ],

    weight: "0.3 lbs",
    dimensions: {
      type: "rectangle",

      length: "4.25 in",
      width: "3.75 in",
      height: "8.5 in",
      trim: [0.125, 0.85],
      soft: true,
    },

    material: ["nylon", "plastic"],
    looks_like: "holster",
    repairs_like: "legrig",

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Water bottle pouch",

        // * while this pouch clearly can store more than a single item, for the sake of sanity and reasonable inventory management, we reduce it to a holster with minimum item-size requirements
        holster: true,

        max_contains_weight: "3 kg",
        // * from source
        max_contains_volume: "1 L 600 ml",
        min_item_volume: "600 ml",
        min_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "trim", value: 0.45 },
            { op: "convert", value: "mm" },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "trim", value: 0.05 },
            { op: "convert", value: "mm" },
          ],
        },

        volume_encumber_modifier: 0.5,

        moves: 150,
      },
    ],

    price: "29 USD 99 cents",
  },
  {
    id: "pouch/radio/tasm",
    inherit: ["@pouch/small", "@holster/radio"],
    type: "ITEM",

    /*
      SOURCES
        https://tasmaniantigerusa.com/product.php?id=33
    */

    name: {
      str: "skinny radio pouch",
      str_pl: "skinny radio pouches",
    },
    description: "A skeletonized nylon pouch made with two orthogonal straps supported by elastic bands and a generous amount of threading.  Intended to hold a full-sized two-way radio for military communications, it can hold a single smaller item in its stead.",

    variant_type: "gun",
    variants: [
      {
        from: [["black", 2], ["coyote", 2], "olive"],

        name: {
          str: "Tasmanian Tiger radio pouch",
          str_pl: "Tasmanian Tiger radio pouches",
        },
        description: "A skeletonized nylon pouch made with two orthogonal straps supported by elastic bands and a generous amount of threading.  Intended to hold a full-sized two-way radio for military communications, it can hold a single smaller item in its stead.",
      },
    ],

    weight: "3.5 oz",
    dimensions: [
      {
        // * VERTICAL STRAP
        type: "rectangle",

        // * 6 in. of stated height + 2/3 of the same height from the back
        length: "10 in",
        // * estimated
        width: "1.5 in",
        height: "3 mm",
        soft: true,
      },
      {
        // * HORIZONTAL STRAP
        type: "rectangle",

        // * stated width of 3.75 in × 2 for both sides
        length: "7.5 in",
        // * estimated
        width: "2 in",
        height: "2 mm",
        soft: true,
      },
    ],

    material: ["nylon", "plastic"],
    looks_like: "holster",
    repairs_like: "legrig",

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Tactical radio pouch",

        holster: true,

        max_contains_weight: {
          math: [
            { ref: "two_way_radio", key: "weight" },
            {
              op: "add",
              value: {
                ref: "light_battery_cell",
                type: "ITEM",
                key: "weight",
              },
            },
            { op: "multiply", value: 1.5 },
          ],
        },
        // * to prevent storing smaller items that may fall through the open corners of the pouch
        min_item_volume: "200 ml",
        max_contains_volume: {
          ref: "two_way_radio",
          key: "volume",
        },
        max_item_length: { ref: "two_way_radio", key: "longest_side" },

        moves: 120,
      },
    ],

    price: "22 USD 95 cents",
  },
  {
    id: "pouch/gadget/condor",
