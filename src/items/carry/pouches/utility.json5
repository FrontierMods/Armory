              ],
            },
            { op: "multiply", value: "2.72 in" },
            { op: "multiply", value: "0.52 in" },
          ],
        },
        min_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "multiply", value: 0.5 },
            { op: "convert", value: "mm" },
          ],
        },
        // * uses 80% of the pouch's height for length, to enable easy access to pouches behind the straps
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "multiply", value: 0.8 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 280,
      },

      {
        pocket_type: "CONTAINER",

        description: "Tool pouch inner strap – front, small",

        multi: 10,

        // * fits the Benchmade 42 balisong well (https://www.balisong.cz/sbirka/eng/myknife9.php)
