  {
    id: "pouch/tool/wynex",
    inherit: ["@pouch/large"],
    type: "ITEM",

    /*
      SOURCES
        https://www.amazon.com/WYNEX-Tactical-Laser-Cut-Organizer-Attachment/dp/B097M7XH5M
    */

    /*
      NOTES
        it's apparent that the inner strap pockets on each side are mirrored, or at least intended to be
        https://www.ebay.com/itm/314954726581
        that's how we model them, without adjusting for any specific pocket's capacity
    */

    name: {
      str: "tactical tool pouch",
      str_pl: "tactical tool pouches",
    },
    description: "A compact pouch for storing small tools.  Can be attached to webbing and carried on your backpack or load-bearing vest.",

    variant_type: "gun",
    variants: [
      {
        from: [["multicam", 2], ["coyote", 2], "black", "ranger"],

        name: {
          str: "WYNEX tactical tool pouch",
          str_pl: "WYNEX tactical tool pouches",
        },
        description: "A compact, low-profile MOLLE pouch for storing small tools and miscellanea.  Features half-a-dozen different pockets, including one on the outside that's the perfect fit for a smartphone, and even more straps on the inside.",
      },
    ],

    weight: "9.8 oz",
    dimensions: {
      type: "rectangle",

      length: "1.2 in",
      width: "8.8 in",
      height: "6.8 in",
      trim: 0.05,
    },

    material: ["nylon"],
    looks_like: "legrig",
    repairs_like: "legrig",

    pocket_data: [
      {
        pocket_type: "CONTAINER",

        description: "Tool pouch flap pocket",

        max_contains_weight: "500 g",
        max_contains_volume: {
          math: [
            {
              // * volume of an iPhone 11 Pro (as mentioned in the listing)
              math: [
                "144 mm",
                { op: "multiply", value: "71.4 mm" },
                { op: "multiply", value: "8.1 mm" },
                // * trim not included to calculate a more concrete volume for the pocket
              ],
            },
            // * +10% since the smartphone didn't occupy the entire pocket
            { op: "multiply", value: 1.1 },
          ],
        },
        max_item_length: {
          math: [
            // * use most of the pouch's width; allows for side seams
            { ref: "$", path: ["dimensions", "width"], raw: true },
            { op: "multiply", value: 0.95 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 210,
      },

      {
        pocket_type: "CONTAINER",

        description: "Tool pouch front pocket",

        multi: 2,

        max_contains_weight: "250 g",
        max_contains_volume: {
          math: [
            {
              math: [
                { ref: "$", path: ["dimensions", "height"], raw: true },
                { op: "multiply", value: 0.9 },
              ],
            },
            {
              op: "multiply",
              value: {
                math: [
                  { ref: "$", path: ["dimensions", "width"], raw: true },
                  { op: "multiply", value: 0.95 },
                  { op: "trim", value: 0.5 },
                ],
              },
            },
            // * depth taken from Leatherman Wave+
            // > https://www.leatherman.com/wave-10.html
            { op: "multiply", value: "0.7 in" },
            // * to account for the pocket not being able to stretch to 0.7 in. across the entire pocket
            { op: "trim", value: 0.5 },
          ],
        },
        // * item length bound by front pocket height
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "multiply", value: 0.9 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 260,
      },

      {
        pocket_type: "CONTAINER",

        description: "Tool pouch inner pocket",

        max_contains_weight: "350 g",
        max_contains_volume: {
          math: [
            {
              math: [
                { ref: "$", path: ["dimensions", "height"], raw: true },
                { op: "multiply", value: 0.95 },
              ],
            },
            {
              op: "multiply",
              value: {
                math: [
                  { ref: "$", path: ["dimensions", "width"], raw: true },
                  { op: "multiply", value: 0.95 },
                ],
              },
            },
            // * thickness of an iPad
            { op: "multiply", value: "0.3 in" },
            // * to account for pocket not being able to stretch fully across entire pocket
            { op: "trim", value: 0.125 },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "width"], raw: true },
            { op: "multiply", value: 0.95 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 280,
      },

      {
        pocket_type: "CONTAINER",

        description: "Tool pouch zippered inner pocket",

        max_contains_weight: "250 g",
        max_contains_volume: {
          math: [
            {
              math: [
                { ref: "$", path: ["dimensions", "height"], raw: true },
                { op: "multiply", value: 0.875 },
              ],
            },
            {
              op: "multiply",
              value: {
                math: [
                  { ref: "$", path: ["dimensions", "width"], raw: true },
                  { op: "multiply", value: 0.95 },
                ],
              },
            },
            // * thickness
            // * slightly smaller than the full-width pocket
            { op: "multiply", value: "0.2 in" },
            // * to account for pocket not being able to stretch fully across entire pocket
            { op: "trim", value: 0.125 },
          ],
        },
        // * slightly shorter than full inner-pocket width due to zipper track and seams
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "width"], raw: true },
            { op: "multiply", value: 0.9 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 280,
      },

      {
        pocket_type: "CONTAINER",

        description: "Tool pouch inner strap – back, small",

        multi: 2,

        // * by width and thickness, fits exactly the Leatherman Skeletool CX
        // > https://www.leatherman.com/products/skeletool-cx

        max_contains_weight: "350 g",
        max_contains_volume: {
          math: [
            {
              // * uses 80% of the pouch's height for length, to enable easy access to pouches behind the straps
              math: [
                { ref: "$", path: ["dimensions", "height"], raw: true },
                { op: "multiply", value: 0.8 },
              ],
            },
            { op: "multiply", value: "1.24 in" },
            // * thickness
            // * same as the other straps to maintain parity
            { op: "multiply", value: "0.52 in" },
          ],
        },
        min_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "multiply", value: 0.5 },
            { op: "convert", value: "mm" },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "multiply", value: 0.8 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 280,
      },

      {
        pocket_type: "CONTAINER",

        description: "Tool pouch inner strap – back, medium",

        multi: 2,

        max_contains_weight: "400 g",
        max_contains_volume: {
          math: [
            {
              // * uses 80% of the pouch's height for length, to enable easy access to pouches behind the straps
              math: [
                { ref: "$", path: ["dimensions", "height"], raw: true },
                { op: "multiply", value: 0.8 },
              ],
            },
            {
              op: "multiply",
              // * get average of large and small strap width
              value: {
                math: [
                  // * width of large strap
                  "2.75 in",
                  {
                    op: "add",
                    // * width of small strap
                    value: "1.25 in",
                  },
                  { op: "divide", value: 2 },
                ],
              },
            },
            // * thickness
            // * same as the other straps to maintain parity
            { op: "multiply", value: "0.52 in" },
          ],
        },
        min_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "multiply", value: 0.5 },
            { op: "convert", value: "mm" },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "height"], raw: true },
            { op: "multiply", value: 0.8 },
            { op: "convert", value: "mm" },
          ],
        },

        moves: 280,
      },

      {
        pocket_type: "CONTAINER",

        description: "Tool pouch inner strap – back, large",

        multi: 2,

        // * fits the Otterbox power bank well
        // > https://www.otterbox.co.uk/en-gb/portable-power-bank-usb-a-and-usb-c-grey/78-80641.html

        max_contains_weight: "500 g",
        max_contains_volume: {
