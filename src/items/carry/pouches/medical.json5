            { ref: "$", path: ["dimensions", "length"] , raw: true},
            {
              op: "multiply",
              value: { ref: "$", path: ["dimensions", "width"] , raw: true},
            },
            {
              op: "multiply",
              value: "3.5 in",
            },
            { op: "multiply", value: 0.95 },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "length"] , raw: true},
            { op: "multiply", value: 0.95 },
          ],
        },

        moves: 210,
      },

      {
        pocket_type: "CONTAINER",

        description: "Short medical elastic band",

        max_contains_weight: "1 kg",
        max_contains_volume: {
          math: [
            { ref: "$", path: ["dimensions", "length"] , raw: true},
            { op: "divide", value: 2 },
            {
              op: "multiply",
              value: { ref: "$", path: ["dimensions", "width"] , raw: true},
            },
            {
              op: "multiply",
              value: "3.5 in",
            },
            // * the small straps are not as accomodating
            { op: "multiply", value: 0.9 },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "width"] , raw: true},
            { op: "multiply", value: 0.95 },
          ],
        },

        moves: 210,
      },
      {
        pocket_type: "CONTAINER",

        description: "Short medical elastic band",

        max_contains_weight: "1 kg",
        max_contains_volume: {
          math: [
            { ref: "$", path: ["dimensions", "length"] , raw: true},
            { op: "divide", value: 2 },
            {
              op: "multiply",
              value: { ref: "$", path: ["dimensions", "width"] , raw: true},
            },
            {
              op: "multiply",
              value: "3.5 in",
            },
            // * the small straps are not as accomodating
            { op: "multiply", value: 0.9 },
          ],
        },
        max_item_length: {
          math: [
            { ref: "$", path: ["dimensions", "width"] , raw: true},
            { op: "multiply", value: 0.95 },
          ],
        },

        moves: 210,
      },
    ],

    price: "25 USD",
  },
