  {
    id: "mili_pilot",
    inherit: "mili_pilot",
    type: "profession",

    patch: [
      // in the US armed forces (either Air Force or Army), pilots are required to complete basic training regardless of their eventual specialization
      // said basic training includes learning to operate in a full set of issued gear, which includes body armor
      {
        op: "append",
        key: "proficiencies",
        value: "prof_plate_carrier",
      },
      // pilots aren't issued with chest rigs or any external webbing
      {
        op: "drop",
        path: "/items/both/entries",
        filter: [{ item: "chestrig" }],
      },
      {
        op: "drop",
        path: "/items/both/entries",
        filter: [{ group: "loaded_webbing_belt" }],
      },
      {
        op: "drop",
        path: "/items/both/entries",
        filter: [{ item: "legpouch_large" }],
      },
      {
        op: "append",
        path: "/items/both/entries",
        value: {
          item: "m17",
          "ammo-item": "9mm",
          "container-item": "nylon_holster",
          charges: 17,
        },
      },
    ],
  },
  {
    id: "prepped_patriot",
    inherit: "prepped_patriot",
    type: "profession",

    patch: [
      // we assume that this is someone who's already had informal training with military-style gear, which would likely include wearing a kitted plate carrier with plates
      {
        op: "append",
        key: "proficiencies",
        value: "prof_plate_carrier",
      },
      {
        op: "replace",
        path: "/items/both/entries",
        filter: [{ item: "chestrig" }],
        value: {
          // TODO: add American-flag nylon patch to the rig when decoration becomes available
          group: "prepped_patriot_rig",
        },
      },
    ],
  },
  {
    id: "old_vet",
    inherit: "old_vet",
    type: "profession",

    patch: [
      // as of 2026, being the youngest Old Vet puts the character at being born in 1976, and being of age for military service in 1994
      // between 1994 and 2026, there have been a few military conflicts in which US troops had been involved extensively
      // as such, we presume that this person has had conventional ballistic armor training
      {
        op: "append",
        key: "proficiencies",
        value: "prof_plate_carrier",
      },
      {
        op: "drop",
        path: "/items/both/entries",
        filter: [{ group: "pipe_smoke" }],
      },
      {
        op: "replace",
        path: "/items/both/entries",
        filter: [{ item: "chestrig" }],
        value: {
          item: "chest_rig/molle_ii/flc",
          "contents-group": "old_vet_rig_magazines_pouched",
        },
      },
      {
        op: "append",
        path: "/items/both/entries",
        value: {
          item: "pipe_tobacco",
        },
      },
      {
        op: "append",
        path: "/items/both/entries",
        value: {
          item: "tobacco",
        },
      },
      {
        op: "append",
        path: "/items/both/entries",
        value: {
          item: "pants",
          variant: "pants_british_khaki",
        },
      },
    ],
  },
