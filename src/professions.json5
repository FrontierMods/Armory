  {
    id: "park_ranger",
    inherit: "park_ranger",
    type: "profession",

    patch: [
      // the Rangers appear to generally be armed with batons and pepper sprays, similarly to the police
      // > https://www.bostonherald.com/2014/10/16/gelzinis-giving-park-rangers-guns-not-the-answer/
      // pouches for the leather belt (which replaces an out-of-place police belt) will be added once belts become audited
      {
        op: "replace",
        path: "/items/both/entries",
        filter: [{ item: "police_belt" }],
        value: {
          item: "leather_belt",
        },
      },

      {
        op: "drop",
        path: "/items/both/entries",
        filter: [{ item: "legpouch_large" }],
      },

      // park rangers in Massachusetts do not appear to be permitted to carry firearm unless their job is in Boston(?), in which case they're required to complete Special Officer training, which permits them to carry a sidearm
      // > https://www.parkrangeredu.org/massachusetts/
      // in general, only the Law Enforcement Ranger position permits carrying a sidearm, since it requires the capacity to enforce the law
      // > https://www.parkrangeredu.org/careers/
      // however, evidence is unclear, given that different sources say different things about whether or not park rangers are law enforcement
      // > https://www.gamewarden.org/career/park-ranger
      {
        op: "drop",
        path: "/items/both/entries",
        filter: [{ item: "p320_357sig" }],
      },
    ],
  },
